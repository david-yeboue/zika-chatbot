# ─── ZIKA Backend – Variables d'environnement ────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs

# Clé API Anthropic (OBLIGATOIRE – ne jamais exposer côté client)
# Obtenir sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-REMPLACER_PAR_VOTRE_CLE

# Serveur
PORT=3001
NODE_ENV=production

# Origines autorisées (séparées par des virgules)
# En développement : http://localhost:5173
# En production : domaine(s) du site ECT
ALLOWED_ORIGINS=https://www.ect.ci,https://ect.ci

# Rate limiting
RATE_LIMIT_MAX=30        # requêtes max par fenêtre
RATE_LIMIT_WINDOW=60000  # fenêtre en ms (60000 = 1 minute)

# Modèle Claude utilisé
CLAUDE_MODEL=claude-sonnet-4-20250514

# Tokens max par réponse IA
MAX_TOKENS=1024
